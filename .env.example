# Copy this file to `.env` and fill in your own values (or just `export` them).
#   cp .env.example .env
# The real `.env` is git-ignored. NEVER commit tokens or private paths.

# ---- Hugging Face ----
# Create a READ token at https://huggingface.co/settings/tokens
# You must also accept the model licenses (once, while logged in):
#   https://huggingface.co/google/medgemma-4b-it        (CURE base)
#   https://huggingface.co/pamessina/medgemma-4b-it-cure (CURE adapter)
#   https://huggingface.co/microsoft/maira-2
HF_TOKEN=

# ---- Dataset location ----
# Dataset root containing:
#   grounded_reports_20240819.json
#   Padchest_GR_files/            (the .png chest X-rays)
DATA_DIR=/data

# ---- Run options (bf16 full precision, NO 4-bit) ----
DEVICE=cuda          # cuda | cpu
N_IMAGES=200         # size of the shared image list
SHUFFLE_SEED=42      # deterministic selection seed
MODELS=cure,maira2   # subset for run_vast.sh, e.g. "cure" or "maira2"
SAVE_FIGURES=0       # 1 = save per-image box previews during `run`
