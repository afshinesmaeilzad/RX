# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
# The real `.env` is git-ignored. NEVER commit tokens or private paths.

# ---- Hugging Face ----
# Create a READ token at https://huggingface.co/settings/tokens
# You must also accept the model licenses (once, while logged in):
#   https://huggingface.co/pamessina/medgemma-4b-it-cure
#   https://huggingface.co/microsoft/maira-2
#   https://huggingface.co/google/medgemma-1.5-4b-it
HF_TOKEN=

# ---- Dataset location on the HOST ----
# A local copy OR an rclone Google Drive mount (see scripts/setup_gdrive.sh).
# This folder is bind-mounted read-only into the container at /data.
# It should contain: grounded_reports_20240819.json and Padchest_GR_files/
DATA_DIR_HOST=./data

# ---- Run options ----
DEVICE=cuda          # cuda | cpu
USE_4BIT=1           # 1 = 4-bit quantization (fits 16GB GPUs); 0 = bf16 (needs 24GB)
N_IMAGES=1           # bump to 10, 200, ... to scale the evaluation
MODELS=cure,maira2,medgemma15   # subset e.g. "cure" or "cure,maira2"
